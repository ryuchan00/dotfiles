# Mac OS X pasteboardを使用できるようにする
set-option -g default-command "reattach-to-user-namespace -l zsh"

# デフォルトのプレフィックスキーはctrl + bだが、シェルの操作とぶつかるので、ctrl + tに変更する
unbind C-b
set-option -g prefix C-t
bind C-t send-prefix

# コピーモードでvimキーバインドを使う
setw -g mode-keys vi

# 'v' で選択を始める
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi y send-keys -X copy-pipe "reattach-to-user-namespace pbcopy"

# `Enter` でもcopy-pipeを使う
unbind -T copy-mode-vi Enter
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "reattach-to-user-namespace pbcopy"

# ']' でpbpasteを使う
bind ] run "reattach-to-user-namespace pbpaste | tmux load-buffer - && tmux paste-buffer"

# 新しいウィンドウ・ペインを現在のディレクトリで開く
bind ^c new-window -c "#{pane_current_path}"
bind '"' split-window -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"
unbind ^t
bind ^n next-window
bind ^p previous-window

# bufferの行数を53万にする
set -g history-limit 530000

# マウス操作を有効にする（スクロール、ペイン選択、リサイズ等）
set -g mouse on

# ペイン移動: vimキーバインド
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# ペイン移動: アローキー
bind Left select-pane -L
bind Down select-pane -D
bind Up select-pane -U
bind Right select-pane -R

# ペインリサイズ: vimキーバインド（大文字）
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# アクティブペインと非アクティブペインの色分け
# 非アクティブ: テキストも暗くして明確に区別
set -g window-style 'fg=colour245,bg=colour236'
set -g window-active-style 'fg=colour255,bg=terminal'
set -g pane-border-style 'fg=colour238,bg=colour236'
set -g pane-active-border-style 'fg=colour51,bg=terminal'

# Claude Code hook可視化用: ボーダー上部にアラートまたはコマンド名を表示
# @pane-alertがセットされたペインだけ🔔付きの目立つラベルを表示する
set -g pane-border-status top
set -g pane-border-format ' #{?@pane-alert,🔔 #{@pane-alert},#{pane_current_command}} '

# フォーカスが戻ったpaneの🔔マーキングを自動リセットする
set-hook -g after-select-pane[0] 'set-option -p -u @pane-alert'
set-hook -g after-select-pane[1] 'set -w -u window-status-style'

# プラグイン管理 (TPM)
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

# セッション自動保存・自動復元
set -g @continuum-restore 'off'
set -g @continuum-save-interval '15'

# resurrect: ペインの内容も保存
set -g @resurrect-capture-pane-contents 'on'

# TPM初期化（この行は必ず.tmux.confの最後に置く）
run '~/.tmux/plugins/tpm/tpm'
