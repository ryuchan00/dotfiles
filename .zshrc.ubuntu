[ -f ~/.zshrc.base ] && source ~/.zshrc.base

export HISTFILE=~/.zsh_history

if [ -x "`which go`" ]; then
  export GOPATH=$HOME/go
  export PATH="$GOPATH/bin:$PATH"
fi
export PATH="$HOME/.local/bin:$PATH"

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS="--reverse --height 40%"

eval "$(starship init zsh)"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# git logの文字化けを防ぐ
export LESSCHARSET=utf-8
export LANG=C.UTF-8

if [ -e '/home/votoms/.env' ]; then
  source '/home/votoms/.env' # 秘匿しなきゃいけないじょうほうはここ
fi
# export DISPLAY=$(cat /etc/resolv.conf | grep nameserver | awk '{print $2}'):0.0

function open() {
  cmd.exe /c start $(wslpath -w $1) > /dev/null 2>&1
}
alias say='cmd.exe /c %USERPROFILE%/say'

#export WIN_USERNAME=$(powershell.exe '$env:USERNAME' | sed -e 's/\r//g')
export WIN_USERHOME=/mnt/c/Users/$WIN_USERNAME
source /home/votoms/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
export PATH=$HOME/.dotnet/tools:$PATH

# Claude Code alias
alias cl='claude'
